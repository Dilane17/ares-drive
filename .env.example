# ============================================================
# ARES DRIVE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# ============================================================

# ----------------------------------------------------------
# SUPABASE
# Dashboard → Settings → API
# ----------------------------------------------------------

# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL= 

# Clé anonyme (safe to expose — sécurisée par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service role (JAMAIS exposée côté client — server only)
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------
# CLOUDINARY
# Dashboard → Settings → API Keys
# ----------------------------------------------------------

# Nom du cloud (visible dans l'URL des images)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# API Key (peut être exposée)
CLOUDINARY_API_KEY=

# API Secret (JAMAIS exposée côté client — server only)
CLOUDINARY_API_SECRET=

# Upload preset non signé créé dans Settings → Upload
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ares-drive-vehicles

# ----------------------------------------------------------
# RESEND (Emails)
# Dashboard → Settings → API Keys
# ----------------------------------------------------------
RESEND_API_KEY=
ADMIN_EMAIL=
